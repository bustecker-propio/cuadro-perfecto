# Backend .gitignore for Django/Python project
# Byte‑compiled / optimized / cache
__pycache__/
*.py[cod]

# Django migrations (keep them!)
# (no ignore here)

# SQLite database files
*.sqlite3
db.sqlite3

# Environment files
.env
.venv/
venv/
env/

# Logs
*.log

# Static & media files generated by collectstatic
staticfiles/
media/

# IDE / editor files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db