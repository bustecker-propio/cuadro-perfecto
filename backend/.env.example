# .env.example for Railway deployment
# Copia este archivo a .env y completa los valores.
SECRET_KEY=changeme-secret-key
DEBUG=False
DJANGO_ALLOWED_HOSTS=yourproject.up.railway.app,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://yourproject.pages.dev,https://www.felipebustos.cl
# PostgreSQL será inyectado por Railway en la variable DATABASE_URL
# AWS S3 / R2 (para fotos y firmware)
AWS_ACCESS_KEY_ID=your_aws_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=your_bucket_name
AWS_S3_REGION_NAME=us-east-1
# MQTT broker (HiveMQ Cloud)
MQTT_SERVER=broker.hivemq.com
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_USE_TLS=False
